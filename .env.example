# ─── Base de datos (Neon PostgreSQL) ────────────────────────────────────────
# 1. Ve a https://neon.tech → New Project → nombre "divisia"
# 2. Connection Details → copia "Connection string" (pooled) → DATABASE_URL
# 3. Copia también la URL sin pooling → DATABASE_URL_UNPOOLED
DATABASE_URL="postgresql://neondb_owner:CAMBIA_ESTO@ep-CAMBIA_ESTO-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL_UNPOOLED="postgresql://neondb_owner:CAMBIA_ESTO@ep-CAMBIA_ESTO.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── Next.js ─────────────────────────────────────────────────────────────────
# Generar secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="GENERA_UNO_CON_openssl_rand_-base64_32"

# ─── Admin (credenciales de acceso a Divisia) ────────────────────────────────
ADMIN_EMAIL="tu@email.com"
ADMIN_PASSWORD="una-password-segura"
